[
  {{- $pages := .RegularPages.ByDate.Reverse -}}
  {{- range $index, $page := $pages -}}
    {{- if $index }},{{ end }}
    {{- $slug := $page.Slug | default $page.File.ContentBaseName -}}
    {{- dict
      "title" $page.Title
      "date" ($page.Date.Format "2006-01-02T15:04:05Z07:00")
      "lastmod" ($page.Lastmod.Format "2006-01-02T15:04:05Z07:00")
      "permalink" $page.Permalink
      "slug" $slug
      "tags" ($page.Params.tags | default (slice))
      "categories" ($page.Params.categories | default (slice))
      "wordCount" $page.WordCount
      "readingTime" $page.ReadingTime
      "summary" ($page.Summary | plainify | htmlUnescape | strings.TrimSpace)
      "section" $page.Section
      "draft" $page.Draft
    | jsonify -}}
  {{- end -}}
]
